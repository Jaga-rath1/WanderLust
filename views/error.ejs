<% layout("/layouts/boilerplate.ejs") %>

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 text-center" style="max-width: 600px;">
        <div class="card-body p-5">

            <div class="mb-4">
                <i class="fa-solid fa-triangle-exclamation text-danger" 
                   style="font-size: 4rem;"></i>
            </div>

            <h1 class="display-4 text-danger fw-bold">Oops!</h1>

            <h4 class="mb-3">Something Went Wrong</h4>

            <p class="text-muted fs-5">
                <%= message %>
            </p>

            <a href="/listings" class="btn btn-danger px-4 mt-3">
                Back to Home
            </a>

        </div>
    </div>
</div>