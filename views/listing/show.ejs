<% layout("/layouts/boilerplate") %>

<body>

<div class="container mt-5">

    <div class="row justify-content-center">
        
        <div class="col-12 col-md-10 col-lg-8">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Image Section -->
                <img 
                    src="<%= listing.img.url %>" 
                    class="card-img-top"
                    alt="listing image"
                    style="height: 450px; object-fit: cover;"
                >

                <!-- Card Body -->
                <div class="card-body p-4">

                    <h2 class="card-title fw-bold mb-3">
                        <%= listing.name %>
                    </h2>

                    <h4 class="card-title fw-bold mb-3">
                        Owned By <%= listing.owner.username %>
                    </h4>

                    <p class="text-muted mb-4">
                        <%= listing.description %>
                    </p>

                    <div class="mb-3">
                        <h5 class="fw-semibold">
                            ₹ <%= listing.price.toLocaleString("en-IN") %>
                        </h5>
                    </div>

                    <div class="mb-2">
                        <i class="fa-solid fa-location-dot"></i>
                        <span class="ms-2">
                            <%= listing.location %>, <%= listing.country %>
                        </span>
                    </div>

                    <!-- Buttons -->
                     <% if(currUser && currUser._id .equals(listing.owner._id)){ %>
                    <div class="d-flex gap-3 mt-4">

                        <a 
                            href="/listings/<%= listing._id %>/edit"
                            class="btn btn-dark px-4"
                        >
                            Edit
                        </a>

                        <form 
                            action="/listings/<%= listing._id %>?_method=DELETE" 
                            method="POST"
                        >
                            <button class="btn btn-danger px-4">
                                Delete
                            </button>
                        </form>

                    </div>
                    <% } %>
                    

                </div>

            </div>

        </div>

    </div>

</div>
<div>
</div>
<br><br><br><br>
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-12">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">

                    <h3 class="text-center fw-bold mb-4">
                        Leave a Review ⭐
                    </h3>
                    <% if(currUser){ %>

                    <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

                        <!-- Rating -->
                        <div class="mb-4">
                            <label for="rating" class="form-label fw-semibold">
                                Rating
                            </label>

                            <input
                                type="range"
                                class="form-range"
                                min="1"
                                max="5"
                                step="1"
                                name="review[rating]"
                                id="rating"
                            >
                        </div>

                        <!-- Comment -->
                        <div class="mb-4">
                            <label for="comment" class="form-label fw-semibold">
                                Your Review
                            </label>

                            <textarea
                                class="form-control"
                                name="review[comment]"
                                id="comment"
                                rows="5"
                                placeholder="Share your experience..."
                                required
                            ></textarea>
                            <div class="invalid-feedback">
                                Please Add Some Comments For Review
                            </div>
                        </div>

                        <!-- Button -->
                        <div class="d-grid">
                            <button class="btn btn-dark btn-lg rounded-3">
                                Submit Review
                            </button>
                        </div>

                    </form>
                    <% } %>

                </div>
            </div>

        </div>
    </div>
</div>
<br><br>
<div class="container my-5">
<% if(listing.reviews.length != 0){ %>
    <h3 class="fw-bold text-center mb-4">
        Customer Reviews ⭐
    </h3>
<% } %>
    <div class="row g-4">
        <% for(let review of listing.reviews){ %>
            <div class="col-lg-4 col-md-6 col-12">
                <div class="card border-0 shadow-sm h-100 rounded-4">
                    
                    <div class="card-body p-4 d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center fw-bold me-2"
                                     style="width:40px;height:40px;">
                                    J
                                </div>

                                <div>
                                    <h6 class="mb-0 fw-bold"><%= review.author.username %></h6>
                                    <small class="text-muted">
                                        <i class="fa-solid fa-circle-check text-primary"></i>
                                        Verified Guest
                                    </small>
                                </div>
                            </div>

                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                ⭐ <%= review.rating %>/5
                            </span>

                        </div>

                        <p class="card-text text-secondary">
                            "<%= review.comment %>"
                        </p>

                        <div class="mt-auto pt-3 d-flex justify-content-end">
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>

                    </div>

                </div>
            </div>
        <% } %>
    </div>
</div>
<div class="map-container">
    <h4 class="map-title">📍 Where You'll Be</h4>
    <div
    id="map"
    data-coordinates='<%- JSON.stringify(listing.geometry.coordinates) %>'
    data-api-key="<%= process.env.GEOAPIFY_API_KEY %>">
</div>
</div>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/map.js"></script>
</body>